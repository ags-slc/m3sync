#!/usr/bin/env sh

# m3sync: minimalistic multi-machine sync
#
# Full-duplex (non-concurrent) synchronization, with minimal requirements.
#
# This script is essentially a lightweight wrapper around the wonderfully
# robust and efficient rsync.
#
# Usage:
#   m3sync [-cdhnov] source_dir target_uri
#
# While m3sync does not allow for concurrency, it solves for some common use
# cases, and can be an effective synchronization utility provided the user
# understands the limitations.
#
# POSIX and mostly POSIX-compliant systems should be compatible with m3sync. The
# feature set is purposefully minimal to acheive maximum portability, and in
# order to limit external dependencies.
#
# This tool began as a thought experiment on how to create a bi-directional file
# synchronization tool using only utilities that are commonly available at every
# (POSIX) command line.
#
# Copyright (C) 2018 Andrew G. Spencer <ags@iomaestro.com>. All rights reserved.
# Please see LICENSE for additional details.

set -e

#
# Shell-related globals.
#
typeset -r  program="${0##*/}"
typeset -r  oifs=$IFS
# Second precision plus PID so two runs in the same second still produce
# distinct changelog/<ts>/ and backup/<ts>/ entries. Not readonly so
# retry/resume paths can re-derive it if ever needed (BUG-05, BUG-13).
typeset     timestamp=$(date '+%Y%m%d%H%M%S').$$

#
# Option and parameter globals.
#
typeset     mode="mirror"
typeset -i  is_enabled=1
typeset -i  is_dry_run=0
typeset -i  is_verbose=0
typeset -i  is_debug=0
typeset -i  is_openrsync=0
typeset -i  can_override=0
typeset -i  can_sync_cvsignore=0
typeset -ir timeout=15
typeset     source_dir=
typeset     target_uri=
typeset     target_host=
typeset     target_dir=

#
# Control files
#
typeset -r  cf_dir=".m3sync"
typeset -r  cf_settings="${cf_dir}/settings"
typeset -r  cf_last_run="${cf_dir}/last-run"
typeset -r  cf_previous_state="${cf_dir}/previous-state"
typeset -r  cf_current_state="${cf_dir}/current-state"
typeset -r  cf_restore_state="${cf_dir}/restore-state"
typeset -r  cf_delta="${cf_dir}/delta"
typeset -r  cf_protected_list="${cf_dir}/protected-list"
typeset -r  cf_tombstones="${cf_dir}/tombstones"
typeset -r  backup_dir="${cf_dir}/backup"
typeset -r  history_dir="${cf_dir}/changelog"
typeset -r  lock_dir="${cf_dir}/lock"
typeset     active_lock_dir=

#
# Other globals.
#
typeset     rsync_opts=

#
# Usage.
#
typeset -r  help_text="Usage:
    $program [-cdhnov] <source_dir> <target_uri>
    $program -h

Options:
    -c        Enable rsync's cvs-exclude (-C) and copy the user's
              .cvsignore to the remote host. Off by default.
    -d        Log debug messages to STDERR.
    -h        Show this help text.
    -n        Dry run only, do not sync. Implies -v.
    -o        Allow the ${cf_settings} file to override command line options.
    -v        Log warning and notice messages to STDERR."

log_msg() {
    # Log error messages to STDERR, and other messages if debug or verbose is
    # set.
    #
    # Input params:
    # $1 - the message type: error, debug, notice
    # $@ - messages to be logged

    local -r msg_type="${1}"; shift
    local -r msg="$*"

    # Only log debug messages if debug is set.
    if [[ "${msg_type}" = "debug" && "${is_debug}" -eq 0 ]]; then
        return 0
    fi

    # Always log error messages, and other messages as configured.
    if [[ "${msg_type}" = "error" || "${msg_type}" = "debug" || "${is_verbose}" -eq 1 ]]; then
        local log_timestamp=$(date +'%Y-%m-%dT%H:%M:%S%z')
        printf '[%s] %s: %s: %s\n' "${log_timestamp}" "${program}" "${msg_type}" "${msg}" >&2
    fi
}

detect_openrsync() {
    # macOS 13+ ships openrsync (BSD-licensed) as /usr/bin/rsync. openrsync
    # silently fails to honor --delete when combined with -b/--backup-dir,
    # causing deletions to not propagate. Detect and degrade gracefully by
    # disabling backups (rsync -b). See docs/FINDINGS-bugs.md BUG-33.
    rsync --version 2> /dev/null | head -n 1 | grep -q openrsync
}

validate_path_safety() {
    # Refuse paths containing shell metacharacters. These would be
    # interpreted by the remote shell when m3sync runs ssh commands with
    # the path interpolated (is_initialized, initialize_dir). A
    # legitimate sync directory should not contain any of these. See
    # BUG-03.
    #
    # Input params:
    # $1 - a human label for the error message (e.g. "target path")
    # $2 - the path to check
    case "$2" in
        *[\$\`\;\|\&\(\)\<\>\"\'\\\*\?]* )
            log_msg error "$1 contains unsafe characters and is refused: $2"
            exit 1 ;;
    esac
}

parse_sync_params() {
    # Parse the sync params and set the global source and target locations for
    # syncing.
    #
    # Input params:
    # $1 - source directory
    # $2 - target URI

    source_dir=${1}; shift
    target_uri=${1}; shift

    IFS=":"

    # Split the URI into an array, using `set` for maximum portability.
    set ${target_uri}

    if [[ $# -lt 2 ]]; then
        target_dir="${1}"
    else
        target_host="${1}"
        target_dir="${2}"
    fi

    IFS=$oifs

    # Reject any unsafe characters before these values are ever
    # interpolated into an ssh command string.
    validate_path_safety "source path" "${source_dir}"
    validate_path_safety "target path" "${target_dir}"
    if [ -n "${target_host}" ]; then
        validate_path_safety "target host" "${target_host}"
    fi
}

set_overrides() {
    # Read the specified config file and override the global configuration
    # settings found in the file.
    #
    # Input params:
    # $1 - the path to the config file
    # $2 - the config file name

    local -r  config_file="${1}/${2}"

    if [[ -f "${config_file}" ]]; then
        # Case arms use 'if' rather than '&&' so a non-matching test does
        # not leave the loop body with a non-zero exit status (which the
        # old '|| return 0' was silently masking — along with any real I/O
        # error on ${config_file}). Unreadable settings now propagate.
        while read -r setting; do
            set ${setting}

            case "${1}" in
                "enabled" ) if [[ "${2}" = "false" ]]; then is_enabled=0; fi ;;
                "mode"    ) mode=${2} ;;
            esac
        done < "${config_file}"
    fi
}

is_initialized() {
    # Check the initialization status of an m3sync directory.
    #
    # Input params:
    # $1 - the directory to check

    local -r cmd="stat ${1}/${cf_dir}"

    if [[ "${1}" = "${source_dir}" || ! "${target_host}" ]]; then
        ${cmd} 2> /dev/null 1> /dev/null # for portability pete's sake...
    else
        ssh ${target_host} "${cmd}" 2> /dev/null 1> /dev/null
    fi
}

initialize_dir() {
    # Initialize an m3sync directory.
    #
    # Input params:
    # $1 - the directory to initialize

    local -r mkdirs="mkdir -p ${1}/${backup_dir} ${1}/${history_dir}"
    local -r mkcfg="echo enabled true"

    if [[ "${1}" = "${source_dir}" || ! "${target_host}" ]]; then
        ${mkdirs} && ${mkcfg} > ${1}/${cf_settings}
        touch ${1}/${cf_last_run}
    else
        ssh ${target_host} "${mkdirs} && ${mkcfg} > ${1}/${cf_settings}"
    fi

    log_msg debug "initialized ${1}"
}

release_lock() {
    # Release process lock upon EXIT or other trapped signals.
    #
    # Guards against an unset active_lock_dir (the trap could fire before
    # get_lock set it) and uses rmdir so a non-empty lock dir — which
    # would indicate a bug — fails loudly rather than being clobbered by
    # rm -rf.
    if [ -z "${active_lock_dir}" ]; then
        return 0
    fi
    if rmdir "${active_lock_dir}" 2> /dev/null; then
        log_msg debug "lock released"
    else
        log_msg error "failed to release lock at ${active_lock_dir}"
    fi
}

get_lock() {
    # Get a lock to ensure that this is the only active m3sync process for the
    # primary directory. This (slightly naive) method is sufficient for most
    # use cases, and avoids any dependencies upon flock, solo, et al.
    #
    # Input params:
    # $1 - the base path of the lock directory

    if mkdir "${1}/${lock_dir}"; then
        # The trap function cannot take params, set the global active_lock_dir
        # instead.
        active_lock_dir="${1}/${lock_dir}"
        log_msg notice "lock acquired"
        trap release_lock EXIT
    else
        log_msg error "cannot acquire lock"
        exit 1
    fi
}

filtered_find() {
    # Return the filtered list of directories, files and links under $1,
    # with the control directory pruned out. Any additional arguments are
    # passed as extra find predicates (e.g. -newer FILE).
    #
    # Input params:
    # $1 - the directory to traverse (the search root)
    # $@ - additional find predicates (optional)
    #
    # Uses path-scoped ! -path exclusions rather than a post-hoc grep so
    # that (a) a file named e.g. 'notes-.m3sync.txt' is not mistakenly
    # dropped (BUG-06), and (b) an empty result set does not cause the
    # pipeline to exit non-zero and abort the caller under set -e (BUG-34).

    local -r root="${1}"; shift

    log_msg debug "filtered_find root=${root} extra=$*"

    find "${root}" \
        ! -path "${root}" \
        ! -path "${root}/${cf_dir}" \
        ! -path "${root}/${cf_dir}/*" \
        \( -type f -o -type d -o -type l \) \
        "$@" \
        | sed "s;^${root}/;;"
}

get_current_state() {
    # Return the current list of directories, files and links.
    #
    # Input params:
    # $1 - the directory to traverse

    filtered_find ${1}
}

get_delta() {
    # Return the delta of the directory's previous and current states.
    #
    # Input params:
    # $1 - the directory to examine

    if [[ -f ${1}/${cf_previous_state} ]]; then
        # We expect changes, so trap diff's exit code and return 0 instead.
        diff ${1}/${cf_previous_state} ${1}/${cf_current_state} || return 0
    fi
}

get_protected_list() {
    # Return a list of files/directories/links which have been added or removed
    # in the ${source_dir} since the last sync. These files are protected when
    # receiving updates from the ${target_dir}.
    #
    # Input params:
    # $1 - the directory to examine

    log_msg debug "creating protected list"
    # Always protect the control files.
    printf '%s\n' "${cf_dir}*"

    grep "[<|>]" ${1}/${cf_delta} | colrm 1 2

    # TODO: this will protect a file that is modified on the source but deleted
    # from the target within the same synchronization window. Is it even
    # desired or necessary? m3sync is not intended for scenarios where the
    # target and the source are being concurrently modified... the model is one
    # of asynchronous modification.
    filtered_find ${1} -newer ${1}/${cf_last_run}
}

restore_current_state() {
    # Undo the current-/previous-state rotation done by prepare_sync. Called
    # only after a dry-run so the on-disk state looks identical to what
    # was there before the run. The old current-state is now in
    # previous-state (from the rotation); put it back.
    #
    # Input params:
    # $1 - the source directory of the sync
    if [[ -f ${1}/${cf_previous_state} ]]; then
        mv ${1}/${cf_previous_state} ${1}/${cf_current_state}
    else
        # First-ever run: there was no prior current-state, so wipe.
        rm -f ${1}/${cf_current_state}
    fi
    rm -f ${1}/${cf_delta} ${1}/${cf_protected_list}
}

get_backup_opts() {
    # Set the backup option strings for rsync usage.
    #
    # Input params:
    # $1 - the receiving directory

    # openrsync does not honor --delete with -b, so we skip backups entirely
    # there; base_opts is already adjusted in prepare_sync (BUG-33).
    [[ "${is_openrsync}" -eq 1 ]] && return 0

    local -r backup_path="${backup_dir}/${timestamp}"
    local    backup_opts=

    # If the receiver is local, anchor the backup path with an absolute
    # prefix so rsync writes backups under the receiver's control dir. For
    # a remote receiver, the relative form is resolved relative to the
    # rsync destination root — also the receiver's control dir.
    if [[ "${1}" = "${source_dir}" || ! "${target_host}" ]]; then
        backup_opts="--backup-dir=${1}/${backup_path}"
    else
        backup_opts="--backup-dir=${backup_path}"
    fi

    log_msg debug "${backup_opts}"

    printf '%s\n' "${backup_opts}"
}

prepare_sync() {
    # Prepare sync state and options.
    #
    # Input params:
    # $1 - the source directory of the sync

    # Omit rsync's -b (backup) under openrsync, which silently drops --delete
    # when -b is present. See detect_openrsync() and BUG-33.
    local    backup_flag="b"
    [[ "${is_openrsync}" -eq 1 ]] && backup_flag=
    # Gate rsync's -C (cvs-exclude) behind the -c flag. Formerly always on,
    # which silently dropped .git/, *.o, *~, #*# and anything listed in an
    # in-tree .cvsignore. See BUG-10.
    local    cvs_flag=
    [[ "${can_sync_cvsignore}" -eq 1 ]] && cvs_flag="C"
    # No -u (update-only): the protected-list already resolves "who wins"
    # for paths modified since last-run, and -u on the outbound leg would
    # sabotage that by skipping a push whenever the target happens to have
    # a newer mtime — leaving the two sides diverged indefinitely. See
    # BUG-11.
    local -r base_opts="--timeout=${timeout} --delete -a${backup_flag}${cvs_flag}"
    local -r exclude_opts="--exclude=${cf_dir}*"
    local    extra_opts=

    # Scan into a sidecar first so the guard can run before we commit the
    # previous-/current-state rotation. If the guard fires and we exit,
    # state is unchanged and a subsequent override run sees the same
    # pre-abort conditions (BUG-02).
    local -r new_state="${1}/${cf_current_state}.new"
    get_current_state ${1} > "${new_state}"

    # BUG-02: if the fresh scan is empty but the last scan wasn't, the
    # source has been wiped out since last run. Propagating would delete
    # everything on the peer via --delete. Refuse unless explicitly
    # overridden with M3SYNC_ALLOW_EMPTY_SOURCE=1.
    if [[ -s ${1}/${cf_current_state} && ! -s "${new_state}" \
          && "${M3SYNC_ALLOW_EMPTY_SOURCE:-0}" -ne 1 ]]; then
        log_msg error "source is empty but previously had files; refusing to propagate wholesale deletion."
        log_msg error "override with M3SYNC_ALLOW_EMPTY_SOURCE=1 if this is intentional."
        rm -f "${new_state}"
        exit 1
    fi

    # Commit the rotation now that we've passed the guard.
    if [[ -f ${1}/${cf_current_state} ]]; then
        mv ${1}/${cf_current_state} ${1}/${cf_previous_state}
    fi
    mv "${new_state}" ${1}/${cf_current_state}

    get_delta ${1} > ${1}/${cf_delta}
    update_tombstones ${1}
    get_protected_list ${1} | sort -u > ${1}/${cf_protected_list}

    if [[ "${is_dry_run}" -eq 1 ]]; then
        extra_opts="nv"
        # No need to snapshot current-state here; restore_current_state
        # (called from finalize_sync) reverses the rotation by moving
        # previous-state back to current-state.
    fi

    if [[ "${is_verbose}" -eq 1 && "${is_dry_run}" -eq 0 ]]; then
        extra_opts="v"
    fi

    rsync_opts="${exclude_opts} ${base_opts}${extra_opts}"

    log_msg debug "rsync_opts: ${rsync_opts}"
}

update_tombstones() {
    # Fold this run's deletions into the persistent tombstones list,
    # and clear any tombstones the user has intentionally re-added.
    # Prune entries older than M3SYNC_TOMBSTONE_DAYS (default 30). See
    # BUG-37.
    #
    # Input params:
    # $1 - source directory
    local src=$1
    local tombfile="${src}/${cf_tombstones}"
    local deltafile="${src}/${cf_delta}"
    local now retention cutoff tmp
    now=$(date +%s)
    retention="${M3SYNC_TOMBSTONE_DAYS:-30}"
    cutoff=$(( now - retention * 86400 ))

    [ -f "${deltafile}" ] || return 0
    touch "${tombfile}"

    # Collect the set of paths re-added this cycle (diff lines starting
    # with '>'). Tombstone entries matching any of these are cleared.
    local readds="${tombfile}.readds"
    grep '^> ' "${deltafile}" 2> /dev/null | cut -c3- > "${readds}" || true

    # Collect newly-deleted paths ('<' lines). Excludes anything also
    # present in readds (a path that was removed and re-added in the
    # same cycle — leave it alone).
    local deletes="${tombfile}.deletes"
    grep '^< ' "${deltafile}" 2> /dev/null | cut -c3- | \
        awk -v readds="${readds}" '
            BEGIN { while ((getline r < readds) > 0) keep[r]=1 }
            !($0 in keep) { print }
        ' > "${deletes}" || true

    # Rebuild the tombstones file:
    #   - drop entries whose path was re-added this cycle
    #   - drop entries older than cutoff
    #   - append this cycle's new deletions with now as the timestamp
    tmp="${tombfile}.new"
    awk -F'\t' -v cutoff="${cutoff}" -v readds="${readds}" '
        BEGIN { while ((getline r < readds) > 0) dropped[r]=1 }
        !($1 in dropped) && ($2+0) >= cutoff { print }
    ' "${tombfile}" > "${tmp}"
    awk -v now="${now}" '{ printf "%s\t%s\n", $0, now }' "${deletes}" >> "${tmp}"
    # Deduplicate on path while preserving the most recent timestamp.
    sort -t'	' -k1,1 -k2,2nr "${tmp}" | awk -F'\t' '!seen[$1]++' > "${tombfile}"
    rm -f "${tmp}" "${readds}" "${deletes}"
}

purge_tombstoned_paths_on_target() {
    # For each live tombstone, if the target has the path, delete it on
    # the target. Runs before leg 1 so the resurrected file is gone
    # before rsync has a chance to pull it back to source.
    #
    # Input params:
    # $1 - source directory
    local src=$1
    local tombfile="${src}/${cf_tombstones}"
    local path

    [ -s "${tombfile}" ] || return 0

    cut -f1 "${tombfile}" | while IFS= read -r path; do
        case "${path}" in
            ''|*'*'*|*'?'*|*'['*) continue ;;
        esac
        # If the user has re-created the file on source, don't delete it
        # from target; the tombstone will be cleared next run.
        [ -e "${src}/${path}" ] && continue

        if [ -n "${target_host}" ]; then
            ssh "${target_host}" "test -e '${target_dir}/${path}' && rm -rf -- '${target_dir}/${path}'" 2> /dev/null || true
        else
            if [ -e "${target_dir}/${path}" ]; then
                rm -rf -- "${target_dir}/${path}"
                log_msg notice "tombstone: deleted resurrected ${path} on target"
            fi
        fi
    done
}

conflict_name() {
    # Return a Syncthing-style conflict-sibling name for a path. The
    # marker is inserted between the basename stem and the extension,
    # or appended if there is no extension.
    #
    # Input params:
    # $1 - the relative path
    # $2 - a timestamp string (typically YYYYMMDD-HHMMSS)
    # $3 - a short device/host identifier
    local path=$1 ts=$2 host=$3
    local dir base stem ext
    case "${path}" in
        */*) dir="${path%/*}/"; base="${path##*/}" ;;
        *)   dir=""; base="${path}" ;;
    esac
    case "${base}" in
        *.*) ext=".${base##*.}"; stem="${base%.*}" ;;
        *)   ext=""; stem="${base}" ;;
    esac
    printf '%s%s.sync-conflict-%s-%s%s\n' "${dir}" "${stem}" "${ts}" "${host}" "${ext}"
}

compute_conflict_list() {
    # Emit the subset of the protected-list where the target has the
    # same path with different content — i.e. both sides edited the
    # file since the last sync. Uses cksum (POSIX CRC-32), which is
    # plenty for divergence detection (not cryptographic).
    #
    # Input params:
    # $1 - source directory (holds the protected-list)
    local src=$1
    local path local_sum remote_sum
    local plist="${src}/${cf_protected_list}"

    [ -s "${plist}" ] || return 0

    while IFS= read -r path; do
        case "${path}" in
            ''|*'*'*|*'?'*|*'['*) continue ;;
        esac
        [ -f "${src}/${path}" ] || continue
        if [ -n "${target_host}" ]; then
            ssh "${target_host}" "[ -f '${target_dir}/${path}' ]" 2> /dev/null || continue
            remote_sum=$(ssh "${target_host}" "cksum < '${target_dir}/${path}'" 2> /dev/null | awk '{print $1}')
        else
            [ -f "${target_dir}/${path}" ] || continue
            remote_sum=$(cksum < "${target_dir}/${path}" 2> /dev/null | awk '{print $1}')
        fi
        local_sum=$(cksum < "${src}/${path}" 2> /dev/null | awk '{print $1}')
        if [ "${local_sum}" != "${remote_sum}" ]; then
            printf '%s\n' "${path}"
        fi
    done < "${plist}"
}

mark_conflicts_on_target() {
    # For each path where both sides diverged since the last sync,
    # preserve the target's version under a Syncthing-style conflict
    # name and mirror that sibling back to the source so both sides end
    # up showing the loss. The subsequent rsync push then lands
    # source's winning version at the canonical path. See BUG-36.
    #
    # Input params:
    # $1 - source directory
    local src=$1
    local conflicts ts host path cname

    conflicts=$(compute_conflict_list "${src}")
    [ -z "${conflicts}" ] && return 0

    ts=$(date '+%Y%m%d-%H%M%S')
    host=$(hostname -s 2> /dev/null || hostname | cut -d. -f1)

    printf '%s\n' "${conflicts}" | while IFS= read -r path; do
        [ -z "${path}" ] && continue
        cname=$(conflict_name "${path}" "${ts}" "${host}")
        log_msg notice "conflict on ${path}; preserving target version as ${cname}"
        if [ -n "${target_host}" ]; then
            rsync -a "${target_uri}/${path}" "${src}/${cname}" 2> /dev/null
            ssh "${target_host}" "mv -- '${target_dir}/${path}' '${target_dir}/${cname}'"
        else
            cp -- "${target_dir}/${path}" "${src}/${cname}"
            mv -- "${target_dir}/${path}" "${target_dir}/${cname}"
        fi
    done
}

sync_protected() {
    # Sync updates from the $target_dir, while masking source updates.
    #
    # Input params:
    # $1 - the source directory of the sync

    local -r protect_opts="--exclude-from=${1}/${cf_protected_list}"
    local -r backup_opts=$(get_backup_opts ${1})

    rsync ${protect_opts} ${backup_opts} ${rsync_opts} ${target_uri}/ ${source_dir}
}

record_history() {
    # Keep records of changes.
    # TODO: change this to use rsync output instead?
    #
    # Input params:
    # $1 - directory to track

    local -r this_history_dir=${1}/${history_dir}/${timestamp}

    if [[ -f ${1}/${cf_previous_state} ]]; then
        # TODO: fix variable names to avoid duplication
        mkdir -p ${this_history_dir}
        mv ${1}/${cf_previous_state} ${this_history_dir}/previous-state
        mv ${1}/${cf_delta} ${this_history_dir}/delta
    fi
}

sync_cvsignore() {
    # Copy the user's .cvsignore file to the remote host.

    if [[ "${target_host}" ]]; then
        log_msg debug "copying ~/.cvsignore to the target host"
        rsync -a --timeout="${timeout}" ~/.cvsignore "${target_host}":.cvsignore
    else
        log_msg notice ".cvsignore not copied, the target directory is local"
    fi
}

sync() {
    # Sync updates to the $target_dir.
    #
    # Input params:
    # $1 - the source directory of the sync

    local -r backup_opts=$(get_backup_opts ${target_dir})

    [[ "${can_sync_cvsignore}" -eq 1 ]] && sync_cvsignore
    mark_conflicts_on_target "${source_dir}"
    rsync ${backup_opts} ${rsync_opts} ${source_dir}/ ${target_uri}
}

finalize_sync() {
    # Finalize the sync by restoring state (if a dry run) and recording the
    # changes. The last-run control file is also updated.
    #
    # Input params:
    # $1 - the source directory of the sync

    if [[ "${is_dry_run}" -eq 1 ]]; then
        restore_current_state ${1}
    else
        if ! is_initialized ${target_dir}; then
            initialize_dir ${target_dir}
        fi

        record_history ${source_dir}
        touch ${1}/${cf_last_run}
    fi
}

main() {
    # Initialize the mode of operation as specified at the command line.
    while getopts "cdhnov" opt; do
        case "${opt}" in
            c  ) can_sync_cvsignore=1 ;;
            d  ) is_debug=1 ;;
            h  ) mode="usage" ;;
            n  ) is_dry_run=1 ;;
            o  ) can_override=1 ;;
            v  ) is_verbose=1 ;;
            \? ) mode="usage" ;;
        esac
    done
    
    shift "$((OPTIND - 1))"

    if [[ "${mode}" = "usage" || "$#" -lt 2 ]]; then
        printf '%s\n' "${help_text}"
        exit
    fi

    if detect_openrsync; then
        is_openrsync=1
        log_msg notice "openrsync detected: backups disabled (BUG-33)"
    fi

    # Establish the source and target parameters.
    parse_sync_params "$@"

    if [[ "${can_override}" -eq 1 ]]; then
        set_overrides ${source_dir} ${cf_settings}
    fi

    if [[ "${is_enabled}" -eq 1 ]]; then
        if ! is_initialized ${source_dir}; then
            initialize_dir ${source_dir}
        elif is_initialized ${target_dir}; then
            # Both source and target are initialized; enter full-duplex mode.
            mode="full-duplex"
        fi

        log_msg debug "mode:${mode} enabled:${is_enabled} dry-run:${is_dry_run} verbose:${is_verbose}"
        log_msg debug "sync ${source_dir} to ${target_uri}"

        get_lock ${source_dir}
        prepare_sync ${source_dir}

        if [[ "${mode}" = "full-duplex" ]]; then
            # Remove any tombstoned path the peer has resurrected before
            # leg 1 has a chance to pull it back (BUG-37).
            purge_tombstoned_paths_on_target ${source_dir}
            sync_protected ${source_dir}
        fi

        sync ${source_dir} ${target_dir}
        finalize_sync ${source_dir}
    else
        log_msg error "Sync is not enabled for ${source_dir}."
    fi
}

main "$@"
